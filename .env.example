# Telegram Bot API Token (от @BotFather)
BOT_TOKEN=1234567890:ABCdefGHiJkLmNoPqRsTuVwXyZ

# Твой личный ID в Telegram (модерация новостей, алерты)
ADMIN_ID=123456789

# ID основного чата и тестовой группы
MAIN_CHAT_ID=-1001234567890
TEST_CHAT_ID=-1009876543210

# Режим отладки: True — опросы и публикации идут в TEST_CHAT_ID, False — в MAIN_CHAT_ID
DEBUG_MODE=False

# Часовой пояс планировщика (опросы 08:00, отчёты 23:00 и т.д.). Обязательно для продакшена: иначе 08:00 = UTC (в МСК будет 11:00)
TIMEZONE=Europe/Moscow

# Данные для DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Лимит токенов в месяц (опционально). 0 — учёт отключён. Цель по бюджету: ~200–400 ₽/мес (ориентир ~50000–100000 токенов)
# DEEPSEEK_MONTHLY_TOKEN_LIMIT=80000

# Яндекс.Диск API (Токен приложения)
YANDEX_DISK_TOKEN=y0_AgAAAA...

# Данные для Telethon (нужны для чтения постов из чужих каналов)
# Получать на https://my.telegram.org
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Настройки базы данных (путь относительно рабочей директории контейнера)
DATABASE_URL=sqlite+aiosqlite:///./data/badminton_bot.db

# Имена тренеров (отображаются в карточке рейтингов)
# Понедельник и Среда — разные тренеры
TRAINER_MON=Тренер (Пн)
TRAINER_WED=Тренер (Ср)

# YouTube: ID канала (например BWF TV). Опционально.
# YOUTUBE_CHANNEL_ID=UCdBDkMCBO1Ni7Fkys-1dKdA
# Ключ YouTube Data API v3 — если RSS даёт 404, добавьте ключ (Google Cloud Console → APIs → YouTube Data API v3)
# YOUTUBE_API_KEY=AIza...

# VK Видео: токен приложения VK API (для video.get). Опционально — без него кнопка «Видео» работает только с YouTube.
# Получить: https://dev.vk.com → Создать приложение → Ключ доступа. Список каналов: Doc/vk_sources.txt (по одной ссылке на строку).
# VK_ACCESS_TOKEN=vk1.a....
# VK_SOURCES_FILE=Doc/vk_sources.txt

# Правила НФБР в формате .docx — опционально; если задано, текст подставляется в промпт квиза
# Скачать: https://nfbr.ru/documents/rules (сохранить как Doc/pravila_nfbr.docx или указать свой путь)
# RULES_DOCX_FILE=Doc/pravila_nfbr.docx
